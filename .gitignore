# Agent Maestro .gitignore

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Node (for docx-js and other tools)
node_modules/

# Temporary files
*.tmp
*.swp
*.swo
*~

# Environment / secrets
.env
.env.*
credentials.json
04_EXECUTE/tools/vault-maintenance/reports/
04_EXECUTE/tools/vault-maintenance/logs/
04_EXECUTE/runtime/config.yaml

# Tool-generated reports in RECORD (individual tool outputs are working artifacts,
# not vault records — only date-stamped health reports and narratives belong here)
05_RECORD/reports/*_report.md

# Stale report artifacts from misconfigured output paths
04_EXECUTE/tools/vault-maintenance/04_EXECUTE/
